{
    "name": "lightning-levenshtein",
    "version": "0.0.2",
    "description": "Blazing-fast Levenshtein distance with bit-parallel Myers algorithm and early exits.",
    "main": "./dist/lightning-levenshtein.min.js",
    "module": "./dist/lightning-levenshtein.min.js",
    "browser": "./dist/lightning-levenshtein.min.js",
    "types": "./dist/lightning-levenshtein.min.d.ts",
    "type": "module",
    "sideEffects": false,
    "packageManager": "pnpm@10.33.1",
    "exports": {
        ".": {
            "types": "./dist/lightning-levenshtein.min.d.ts",
            "default": "./dist/lightning-levenshtein.min.js"
        },
        "./v2": {
            "types": "./dist/lightning-levenshtein-v2.min.d.ts",
            "default": "./dist/lightning-levenshtein-v2.min.js"
        },
        "./unicode": {
            "types": "./dist/lightning-levenshtein-unicode.min.d.ts",
            "default": "./dist/lightning-levenshtein-unicode.min.js"
        }
    },
    "files": [
        "dist/lightning-levenshtein.min.js",
        "dist/lightning-levenshtein.min.d.ts",
        "dist/lightning-levenshtein-v2.min.js",
        "dist/lightning-levenshtein-v2.min.d.ts",
        "dist/lightning-levenshtein-unicode.min.js",
        "dist/lightning-levenshtein-unicode.min.d.ts",
        "bench/packages/relative-to-fastest-levenshtein.svg",
        "bench/packages/mean-ops-loglog-chart.svg",
        "bench/packages/relative-performance.svg",
        "bench/packages/mean-rank-log-chart.svg",
        "LICENSE.md",
        "README.md"
    ],
    "scripts": {
        "build": "node ./build-gcc.mjs",
        "build:v2": "node ./build-gcc-bolt.mjs",
        "build:unicode": "node ./build-gcc-unicode.mjs",
        "build:all": "pnpm run build && pnpm run build:v2 && pnpm run build:unicode",
        "check:ci": "pnpm run build:all && pnpm run test:build:artifacts && pnpm test --runInBand --verbose && pnpm run test:package && pnpm run test:package:types && pnpm run test:package:tarball && pnpm run test:package:pack",
        "prepublishOnly": "pnpm run check:ci",
        "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js",
        "test:build:artifacts": "node ./scripts/build-artifacts-smoke.mjs",
        "test:package": "node ./scripts/package-smoke.mjs",
        "test:package:pack": "node ./scripts/package-pack-dry-run.mjs",
        "test:package:types": "node ./scripts/package-types-smoke.mjs",
        "test:package:tarball": "node ./scripts/package-tarball-smoke.mjs",
        "html": "http-server . -p 8000 -c-1",
        "html:open": "start http://localhost:8000/bench/benchmark.html",
        "bench": "node bench/bench.js",
        "bench:char-table": "node ./bench/char-table-spike/run-bench.js",
        "bench:peq": "node ./bench/peq-benchmark.mjs",
        "bench:myersx": "node ./bench/myers-x-variants/run-bench.js",
        "bench:myers32": "node ./bench/myers32-variants/run-bench.js",
        "bench:small": "node ./bench/small_kernals/bench-2x-small.js",
        "bench:small-dispatch": "node ./bench/small-dispatch-spike/run-bench.js",
        "bench:packages": "node ./bench/packages/run-bench.js",
        "bench:packages:table": "node ./bench/packages/render-readme-table.js",
        "bench:packages:bar": "node ./bench/packages/render-relative-bar-chart.js",
        "bench:packages:linechart": "node ./bench/packages/render-readme-line-chart.js",
        "bench:packages:percent": "node ./bench/packages/render-readme-relative-fastest-chart.js",
        "bench:packages:rank": "node ./bench/packages/render-readme-rank-chart.js",
        "bench:packages:chart": "pnpm run bench:packages:bar && pnpm run bench:packages:linechart && pnpm run bench:packages:percent && pnpm run bench:packages:rank",
        "bench:packages:all": "pnpm run bench:packages && pnpm run bench:packages:table && pnpm run bench:packages:chart",
        "codegen:myers32:a": "node ./codegen/tools/generateMyers32-A.cjs",
        "codegen:myers32:b": "node ./codegen/tools/generateMyers32-B.cjs",
        "codegen:myers32": "pnpm run codegen:myers32:a && pnpm run codegen:myers32:b"
    },
    "keywords": [
        "levenshtein",
        "distance",
        "fastest",
        "fast",
        "fuzzy",
        "string",
        "search",
        "algorithm",
        "similarity",
        "comparison",
        "bit-parallel",
        "matching",
        "browser",
        "node",
        "js"
    ],
    "author": "Dr.Watt",
    "license": "Dr.Watt",
    "devDependencies": {
        "benchmark": "^2.1.4",
        "fast-levenshtein": "^3.0.0",
        "fastest-levenshtein": "^1.0.16",
        "http-server": "^14.1.1",
        "jest": "^29.0.0",
        "js-levenshtein": "^1.1.6",
        "leven": "^3.1.0",
        "levenshtein-edit-distance": "^3.0.1"
    },
    "directories": {
        "test": "test"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/iWhatty/lightning-Levenshtein.js.git"
    },
    "bugs": {
        "url": "https://github.com/iWhatty/lightning-Levenshtein.js/issues"
    },
    "homepage": "https://github.com/iWhatty/lightning-Levenshtein.js#readme"
}
